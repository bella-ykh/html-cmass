<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>삼국시대 수업 자료 — 475 AD</name>
  <description>AI로 생성한 한국사 지도 수업 자료 샘플 (고구려·백제·신라)</description>

  <!-- ==========================================
       스타일 정의
       HTML의 CSS처럼, 여기서 색/모양을 미리 정해두고
       아래 Placemark에서 id로 불러씁니다
  =========================================== -->

  <!-- 고구려 영토 스타일 (초록) -->
  <Style id="style_goguryeo_territory">
    <LineStyle>
      <color>ff00aa44</color>
      <width>2</width>
    </LineStyle>
    <PolyStyle>
      <color>6600aa44</color><!-- 투명도 포함: 66=약 40% 불투명 -->
    </PolyStyle>
  </Style>

  <!-- 백제 영토 스타일 (파랑) -->
  <Style id="style_baekje_territory">
    <LineStyle>
      <color>ffcc6600</color>
      <width>2</width>
    </LineStyle>
    <PolyStyle>
      <color>66cc6600</color>
    </PolyStyle>
  </Style>

  <!-- 신라 영토 스타일 (빨강) -->
  <Style id="style_silla_territory">
    <LineStyle>
      <color>ff0000cc</color>
      <width>2</width>
    </LineStyle>
    <PolyStyle>
      <color>660000cc</color>
    </PolyStyle>
  </Style>

  <!-- 수도 핀 스타일 (별 모양 아이콘) -->
  <Style id="style_capital">
    <IconStyle>
      <color>ff00ffff</color>
      <scale>1.2</scale>
      <Icon>
        <href>http://maps.google.com/mapfiles/kml/shapes/star.png</href>
      </Icon>
    </IconStyle>
    <LabelStyle>
      <color>ffffffff</color>
      <scale>1.0</scale>
    </LabelStyle>
    <BalloonStyle>
      <text><![CDATA[
        <b>$[name]</b><br/>
        $[description]
      ]]></text>
    </BalloonStyle>
  </Style>

  <!-- 주요 사건 핀 스타일 (동그라미) -->
  <Style id="style_event">
    <IconStyle>
      <color>ff0088ff</color>
      <scale>0.9</scale>
      <Icon>
        <href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href>
      </Icon>
    </IconStyle>
    <LabelStyle>
      <scale>0.85</scale>
    </LabelStyle>
  </Style>


  <!-- ==========================================
       레이어 1: 수도 (핀)
       Point = 좌표 하나 = 지도 핀
  =========================================== -->
  <Folder>
    <name>🏛️ 삼국 수도</name>
    <open>1</open>

    <Placemark>
      <name>평양성 (고구려 수도)</name>
      <description><![CDATA[
        <b>고구려 수도</b><br/>
        장수왕이 427년 국내성에서 평양성으로 천도.<br/>
        한반도 지배 확대의 전진기지.
      ]]></description>
      <styleUrl>#style_capital</styleUrl>
      <Point>
        <coordinates>125.7554,39.0194,0</coordinates>
        <!-- 경도, 위도, 고도 순서 주의! (HTML x,y 순서랑 반대) -->
      </Point>
    </Placemark>

    <Placemark>
      <name>웅진 (백제 수도)</name>
      <description><![CDATA[
        <b>백제 수도</b><br/>
        475년 고구려 장수왕의 침략으로 한성 함락 후<br/>
        웅진(現 공주)으로 수도 이전.
      ]]></description>
      <styleUrl>#style_capital</styleUrl>
      <Point>
        <coordinates>127.1139,36.4647,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>금성 (신라 수도)</name>
      <description><![CDATA[
        <b>신라 수도</b><br/>
        현재의 경주. 건국부터 멸망까지 약 1000년간<br/>
        신라의 수도였던 곳.
      ]]></description>
      <styleUrl>#style_capital</styleUrl>
      <Point>
        <coordinates>129.2239,35.8562,0</coordinates>
      </Point>
    </Placemark>

  </Folder>


  <!-- ==========================================
       레이어 2: 주요 사건 (핀)
  =========================================== -->
  <Folder>
    <name>⚔️ 주요 사건 (475 AD)</name>
    <open>0</open>

    <Placemark>
      <name>한성 함락 (475 AD)</name>
      <description><![CDATA[
        <b>고구려의 한성 함락</b><br/>
        장수왕이 3만 병력으로 백제 수도 한성을 공격.<br/>
        백제 개로왕 전사. 백제는 웅진으로 남천.
      ]]></description>
      <styleUrl>#style_event</styleUrl>
      <Point>
        <coordinates>127.0000,37.5665,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>광개토대왕릉비</name>
      <description><![CDATA[
        <b>광개토대왕릉비 위치</b><br/>
        414년 장수왕이 아버지 광개토대왕의 업적을 기린 비석.<br/>
        현재 중국 지린성 지안시에 소재.
      ]]></description>
      <styleUrl>#style_event</styleUrl>
      <Point>
        <coordinates>126.1873,41.1483,0</coordinates>
      </Point>
    </Placemark>

  </Folder>


  <!-- ==========================================
       레이어 3: 영토 (면)
       Polygon = 좌표를 이어서 만든 영역
       마지막 좌표는 첫 번째와 같아야 닫힘
  =========================================== -->
  <Folder>
    <name>🗺️ 삼국 영토 (475 AD 추정)</name>
    <open>1</open>

    <Placemark>
      <name>고구려 영토</name>
      <description>475 AD 기준 고구려 최대 영역 (교육용 단순화 버전)</description>
      <styleUrl>#style_goguryeo_territory</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              124.0,38.5,0
              125.0,42.5,0
              127.5,43.5,0
              130.0,42.0,0
              129.5,40.0,0
              128.5,38.5,0
              127.5,37.8,0
              126.5,37.5,0
              125.5,37.8,0
              124.5,38.0,0
              124.0,38.5,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>

    <Placemark>
      <name>백제 영토</name>
      <description>475 AD 기준 백제 영역 (한성 함락 직후, 교육용 단순화 버전)</description>
      <styleUrl>#style_baekje_territory</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              126.0,37.2,0
              126.5,37.5,0
              127.3,37.0,0
              127.5,36.5,0
              127.2,35.8,0
              126.8,35.0,0
              126.2,34.8,0
              125.8,35.2,0
              125.5,36.0,0
              125.8,36.8,0
              126.0,37.2,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>

    <Placemark>
      <name>신라 영토</name>
      <description>475 AD 기준 신라 영역 (교육용 단순화 버전)</description>
      <styleUrl>#style_silla_territory</styleUrl>
      <Polygon>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              127.5,37.2,0
              128.0,37.5,0
              128.8,37.8,0
              129.5,37.5,0
              130.0,36.5,0
              129.8,35.5,0
              129.2,34.8,0
              128.5,34.5,0
              127.8,34.8,0
              127.3,35.5,0
              127.2,36.5,0
              127.5,37.2,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>

  </Folder>

</Document>
</kml>
